<div class="page-content">
  <h1>{{ 'customers.order' | t }} {{ order.name }}</h1>
  <p>{{ order.created_at | date: '%B %d, %Y' }}</p>
  <table class="cart-table">
    <thead><tr><th>{{ 'cart.product' | t }}</th><th>{{ 'cart.quantity' | t }}</th><th>{{ 'cart.total' | t }}</th></tr></thead>
    <tbody>
      {%- for line_item in order.line_items -%}
        <tr>
          <td>{{ line_item.title }}</td>
          <td>{{ line_item.quantity }}</td>
          <td>{{ line_item.final_line_price | money }}</td>
        </tr>
      {%- endfor -%}
    </tbody>
  </table>
  <p style="margin-top: 20px;"><strong>{{ 'cart.total' | t }}: {{ order.total_price | money }}</strong></p>
  <a href="{{ routes.account_url }}" class="btn btn--ghost">{{ 'customers.back_to_account' | t }}</a>
</div>
