<div class="page-content">
  <h1>{{ 'customers.account' | t }}</h1>
  <p>{{ customer.name }} &middot; <a href="{{ routes.account_logout_url }}">{{ 'customers.log_out' | t }}</a></p>
  <h3>{{ 'customers.order_history' | t }}</h3>
  {%- if customer.orders.size > 0 -%}
    <table class="cart-table">
      <thead><tr><th>{{ 'customers.order' | t }}</th><th>{{ 'customers.date' | t }}</th><th>{{ 'customers.status' | t }}</th><th>{{ 'cart.total' | t }}</th></tr></thead>
      <tbody>
        {%- for order in customer.orders -%}
          <tr>
            <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
            <td>{{ order.created_at | date: '%b %d, %Y' }}</td>
            <td>{{ order.financial_status_label }}</td>
            <td>{{ order.total_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  {%- else -%}
    <p>{{ 'customers.no_orders' | t }}</p>
  {%- endif -%}
</div>
