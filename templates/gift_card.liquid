{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'gift_cards.title' | t: shop: shop.name }}</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <div class="page-content" style="text-align:center;">
    <h1>{{ shop.name }}</h1>
    <h2>{{ 'gift_cards.subtitle' | t }}</h2>
    <p style="font-size: 2rem; font-weight: 700;">{{ gift_card.initial_value | money }}</p>
    <p><code style="font-size: 1.3rem; letter-spacing: 0.1em; background: #f5efe6; padding: 12px 20px; border-radius: 10px; display:inline-block;">{{ gift_card.code | format_code }}</code></p>
    {%- if gift_card.expired -%}
      <p>{{ 'gift_cards.expired' | t }}</p>
    {%- endif -%}
    <a href="{{ shop.url }}" class="btn">{{ 'gift_cards.shop_link' | t }}</a>
  </div>
</body>
</html>
