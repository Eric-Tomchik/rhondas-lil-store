<header class="site-header">
  <div class="site-header__inner">
    <button class="menu-toggle" data-menu-toggle aria-expanded="false" aria-label="{{ 'general.menu' | t }}">
      {% render 'icon', icon: 'menu' %}
    </button>

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name | escape }}" width="150" height="52" loading="eager">
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <nav class="site-nav" data-site-nav aria-label="{{ 'general.menu' | t }}">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="site-header__icons">
      <a href="{{ routes.search_url }}" aria-label="{{ 'general.search' | t }}">
        {% render 'icon', icon: 'search' %}
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" aria-label="{{ 'general.account' | t }}">
          {% render 'icon', icon: 'account' %}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" aria-label="{{ 'general.cart' | t }}">
        {% render 'icon', icon: 'cart' %}
        {%- if cart.item_count > 0 -%}
          <span class="cart-count-bubble">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
