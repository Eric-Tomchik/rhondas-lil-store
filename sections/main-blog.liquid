<div class="page-width section">
  <header class="collection-header" style="padding-top: 0;">
    <h1>{{ blog.title }}</h1>
  </header>
  {%- paginate blog.articles by 12 -%}
    <div class="collection-cards">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="collection-card">
          {%- if article.image != blank -%}
            <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title | escape }}" loading="lazy" width="800" height="600">
          {%- else -%}
            <div class="placeholder-media">{% render 'icon', icon: 'placeholder-product' %}</div>
          {%- endif -%}
          <span class="collection-card__label">{{ article.title }}</span>
        </a>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="Pagination">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&larr;</a>{%- endif -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}">&rarr;</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
