<div class="trust-bar">
  <div class="trust-bar__inner">
    {%- for block in section.blocks -%}
      <div class="trust-bar__item" {{ block.shopify_attributes }}>
        {% render 'icon', icon: block.settings.icon %}
        <div>
          <strong>{{ block.settings.title }}</strong>
          <span>{{ block.settings.subtitle }}</span>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust bar",
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "return", "label": "Returns" },
            { "value": "heart", "label": "Heart" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "tag", "label": "Tag" },
            { "value": "chat", "label": "Chat" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Fast, tracked shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Every order, every time" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "item", "settings": { "icon": "truck", "title": "Fast, tracked shipping", "subtitle": "Every order, every time" } },
        { "type": "item", "settings": { "icon": "return", "title": "30-day returns", "subtitle": "No-fuss refunds" } },
        { "type": "item", "settings": { "icon": "shield", "title": "Secure checkout", "subtitle": "SSL-protected payments" } },
        { "type": "item", "settings": { "icon": "chat", "title": "Friendly support", "subtitle": "Real replies, fast" } }
      ]
    }
  ]
}
{% endschema %}
