<article class="page-content">
  <span class="section-kicker">{{ article.published_at | date: '%B %d, %Y' }}</span>
  <h1>{{ article.title }}</h1>
  {%- if article.image != blank -%}
    <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.title | escape }}" style="border-radius: 14px; margin-bottom: 28px;" width="1200" height="675">
  {%- endif -%}
  <div class="rte">{{ article.content }}</div>
</article>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
