<section class="section">
  <div class="page-width">
    {%- if section.settings.kicker != blank -%}
      <span class="section-kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <p class="section-sub">{{ section.settings.subheading }}</p>

    <div class="testimonials">
      {%- for block in section.blocks -%}
        <div class="testimonial" {{ block.shopify_attributes }}>
          <div class="testimonial__stars" aria-label="{{ block.settings.stars }} out of 5 stars">
            {%- for i in (1..block.settings.stars) -%}★{%- endfor -%}
          </div>
          <p class="testimonial__quote">“{{ block.settings.quote }}”</p>
          <div class="testimonial__author">
            {{ block.settings.author }}
            {%- if block.settings.detail != blank -%}
              <span>{{ block.settings.detail }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker text", "default": "Happy shoppers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Don't just take our word for it" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Shipping was quick and the quality blew me away. This is my new go-to gift shop!" },
        { "type": "text", "id": "author", "label": "Author", "default": "Jessica M." },
        { "type": "text", "id": "detail", "label": "Detail line", "default": "Verified buyer" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "Shipping was quick and the quality blew me away. This is my new go-to gift shop!", "author": "Jessica M.", "detail": "Verified buyer" } },
        { "type": "testimonial", "settings": { "quote": "Ordered twice already. Everything arrives exactly as pictured — love this little store.", "author": "Danielle R.", "detail": "Repeat customer" } },
        { "type": "testimonial", "settings": { "quote": "Customer service actually answered me the same day. That alone earned my loyalty.", "author": "Marcus T.", "detail": "Verified buyer" } }
      ]
    }
  ]
}
{% endschema %}
