<section class="section">
  <div class="page-width">
    {%- if section.settings.kicker != blank -%}
      <span class="section-kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <p class="section-sub">{{ section.settings.subheading }}</p>

    <div class="collection-cards">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        <a href="{{ col.url | default: routes.all_products_collection_url }}" class="collection-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt | default: col.title | escape }}" loading="lazy" width="800" height="600">
          {%- elsif col.featured_image != blank -%}
            <img src="{{ col.featured_image | image_url: width: 800 }}" alt="{{ col.title | escape }}" loading="lazy" width="800" height="600">
          {%- else -%}
            <div class="placeholder-media">{% render 'icon', icon: 'placeholder-product' %}</div>
          {%- endif -%}
          <span class="collection-card__label">
            {{ block.settings.title | default: col.title | default: 'sections.collection_list.example' | t }}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker text", "default": "Shop by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your favorites" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From cozy home upgrades to clever gadgets and gifts — there's a little something for everyone." }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Custom title (optional)" },
        { "type": "image_picker", "id": "image", "label": "Custom image (optional)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
