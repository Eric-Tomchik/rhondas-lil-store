<section class="section section--soft">
  <div class="page-width">
    {%- if section.settings.kicker != blank -%}
      <span class="section-kicker">{{ section.settings.kicker }}</span>
    {%- endif -%}
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <p class="section-sub">{{ section.settings.subheading }}</p>

    <div class="value-props">
      {%- for block in section.blocks -%}
        <div class="value-prop" {{ block.shopify_attributes }}>
          <span class="value-prop__icon">{% render 'icon', icon: block.settings.icon %}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value props",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker text", "default": "Why shop with us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Small store, big heart" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "prop",
      "name": "Value prop",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "return", "label": "Returns" },
            { "value": "heart", "label": "Heart" },
            { "value": "tag", "label": "Tag" },
            { "value": "chat", "label": "Chat" }
          ],
          "default": "sparkle"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Curated with care" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every product is hand-picked and quality-checked before it earns a spot in the store." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Value props",
      "blocks": [
        { "type": "prop", "settings": { "icon": "sparkle", "title": "Curated with care", "text": "Every product is hand-picked and quality-checked before it earns a spot in the store." } },
        { "type": "prop", "settings": { "icon": "tag", "title": "Fair little prices", "text": "Great finds shouldn't break the bank. We keep prices friendly, always." } },
        { "type": "prop", "settings": { "icon": "truck", "title": "Shipped with love", "text": "Orders are processed fast and tracked from our door to yours." } }
      ]
    }
  ]
}
{% endschema %}
