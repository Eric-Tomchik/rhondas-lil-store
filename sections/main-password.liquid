<div class="password-page">
  <div class="password-page__card">
    <span class="section-kicker">{{ shop.name }}</span>
    <h1>{{ 'general.password_title' | t }}</h1>
    <p>{{ 'general.password_text' | t }}</p>
    {% form 'storefront_password' %}
      <div class="newsletter-form" style="margin-top: 20px;">
        <input type="password" name="password" placeholder="{{ 'general.password_placeholder' | t }}" style="flex-grow:1; border:1.5px solid rgba(43,33,24,0.2); border-radius:999px; padding:14px 22px; font-family: var(--font-body);">
        <button type="submit" class="btn">{{ 'general.password_submit' | t }}</button>
      </div>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "settings": []
}
{% endschema %}
