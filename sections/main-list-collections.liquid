<div class="page-width section">
  <header class="collection-header" style="padding-top: 0;">
    <h1>{{ 'collections.list_title' | t }}</h1>
  </header>
  <div class="collection-cards">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="collection-card">
        {%- if collection.featured_image != blank -%}
          <img src="{{ collection.featured_image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" loading="lazy" width="800" height="600">
        {%- else -%}
          <div class="placeholder-media">{% render 'icon', icon: 'placeholder-product' %}</div>
        {%- endif -%}
        <span class="collection-card__label">{{ collection.title }}</span>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collections list page",
  "settings": []
}
{% endschema %}
